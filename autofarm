local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/bloodball/-back-ups-for-libs/main/wizard"))()

-- Criando a Janela
local Window = Library:NewWindow("Adopt Me")

-- Criando a Aba Autofarm
local AutoFarmTab = Window:NewSection("Autofarm")

-- BotÃ£o Start Autofarm
AutoFarmTab:CreateButton("Start Autofarm", function()
    game.StarterGui:SetCore("SendNotification", {
        Title = "Autofarm Alert";
        Text = "You must teleport to Valentine Event to start autofarm";
        Duration = 5;
    })
    
    while task.wait(0.25) do
        for a, b in pairs(game:GetService("Workspace").StaticMap.Valentines2025.Hearts:GetChildren()) do
            if b.Name == "CupidHeart" and b:FindFirstChild("Collider") then
                game:GetService("Workspace").PlayerCharacters[game.Players.LocalPlayer.Name].HumanoidRootPart.CFrame = CFrame.new(b.Collider.Position)
            end
        end

        for a, b in pairs(game:GetService("Workspace").StaticMap.Valentines2025.Roses:GetChildren()) do
            if b.Name == "Rose" and b:FindFirstChild("Collider") then
                game:GetService("Workspace").PlayerCharacters[game.Players.LocalPlayer.Name].HumanoidRootPart.CFrame = CFrame.new(b.Collider.Position)
            end
        end
    end
end)
